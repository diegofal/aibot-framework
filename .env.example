# Telegram Bot Tokens
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_BOT_TOKEN_INTEL=9876543210:ZYXwvuTSRqpONMlkJIHgfEDCba

# Ollama Configuration
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Brave Search API (for web tools)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Logging
LOG_LEVEL=info

# Twilio (Phone Call skill)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+0987654321

# OpenAI (Whisper voice transcription)
OPENAI_API_KEY=your-openai-api-key-here

# ElevenLabs (TTS voice output)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Reddit API (OAuth2 script app — reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# Twitter/X API v2 (developer.twitter.com)
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# Calendar (Calendly or Google Calendar)
CALENDAR_API_KEY=your-calendar-api-key
CALENDAR_ID=primary
