{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "data/**",
      "config/**",
      "productions/**"
    ]
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "warn",
        "noBannedTypes": "warn"
      },
      "performance": {
        "noDelete": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noImplicitAnyLet": "warn",
        "noRedeclare": "warn",
        "noAssignInExpressions": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "noParameterAssign": "warn",
        "useTemplate": "warn",
        "useConst": "warn",
        "noUnusedTemplateLiteral": "warn",
        "useDefaultParameterLast": "warn"
      }
    }
  },
  "overrides": [
    {
      "include": [
        "tests/**",
        "src/bot/__tests__/**",
        "src/__tests__/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5"
    }
  }
}
